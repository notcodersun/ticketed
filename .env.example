ADMIN_PASSWORD="replace-with-a-long-random-password"
SESSION_SECRET="replace-with-a-long-random-string"

# SMTP is only needed for server-side Nodemailer sending.
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="smtp-user"
SMTP_PASS="smtp-password"
SMTP_FROM="M.U.M Tickets <tickets@example.com>"
SMTP_CC="42sannay@gmail.com"

# Non-SMTP fallback. If RESEND_API_KEY and EMAIL_FROM are set,
# the server sends through Resend before trying Nodemailer.
RESEND_API_KEY=""
EMAIL_FROM="M.U.M Tickets <myth.official.music7@gmail.com>"
EMAIL_CC="42sannay@gmail.com"
